# ============================================
# SaaS UFOP — Environment Variables (template)
# Copie para .env.local e preencha os valores
# ============================================

# ----- Supabase CLI (Management API) — local/CI only -----
SUPABASE_ACCESS_TOKEN=

# ----- Supabase Project -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Direct DB (migrations / psql) -----
DATABASE_URL=

# ----- Google Service Account (Fase 2) -----
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_RANGE=A1:Z500

# ----- SMTP (Fase 2 - jubilamento alerts) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
